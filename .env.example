# =============================================================================
# Guardian Intel - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Required variables are marked with (REQUIRED).

# =============================================================================
# Database (Supabase PostgreSQL) (REQUIRED)
# =============================================================================
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# =============================================================================
# NextAuth.js Authentication (REQUIRED)
# =============================================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-32-char-secret-here-with-openssl-rand-base64-32

# =============================================================================
# AI Services (at least one recommended)
# =============================================================================
# Google Gemini (primary AI provider)
GOOGLE_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Perplexity (web search augmented)
PERPLEXITY_API_KEY=

# Moonshot
MOONSHOT_API_KEY=

# =============================================================================
# Google Maps (property street view, geocoding)
# =============================================================================
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# =============================================================================
# Supabase (storage, realtime)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=deck-pdfs

# =============================================================================
# CRM Integration (Leap CRM)
# =============================================================================
# CRM_PROVIDER=leap                     # Uncomment and set Leap credentials below to enable
LEAP_API_KEY=
LEAP_COMPANY_ID=
LEAP_BASE_URL=https://api.leapcrm.com
LEAP_WEBHOOK_SECRET=

# =============================================================================
# Rate Limiting (Upstash Redis - optional, falls back to in-memory)
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_ENABLED=true

# =============================================================================
# Outreach Providers (SMS/Email campaigns)
# =============================================================================
# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (Email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Guardian Roofing

# =============================================================================
# Company Branding (used in outreach templates)
# =============================================================================
COMPANY_NAME=Guardian Roofing
COMPANY_PHONE=(555) 123-4567
COMPANY_WEBSITE=guardianroofing.com

# =============================================================================
# Deck Generation (NotebookLM pipeline)
# =============================================================================
NOTEBOOKLM_NOTEBOOK_ID=                  # Reuse an existing notebook (optional)
NOTEBOOKLM_PYTHON_CMD=python3            # Python binary for notebooklm-py bridge
NOTEBOOKLM_BRIDGE_SCRIPT=scripts/notebooklm-bridge.py
NOTEBOOKLM_TIMEOUT_MS=300000             # 5 minute timeout for NotebookLM operations
NOTEBOOKLM_STORAGE_PATH=~/.notebooklm   # Path to NotebookLM credentials

# =============================================================================
# Cron Jobs
# =============================================================================
CRON_SECRET=                             # Shared secret for authenticating cron requests

# =============================================================================
# Push Notifications (VAPID)
# =============================================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=             # VAPID public key for web push
VAPID_PRIVATE_KEY=                        # VAPID private key for web push
VAPID_SUBJECT=mailto:admin@guardian-intel.com

# =============================================================================
# Internal API
# =============================================================================
INTERNAL_API_KEY=                         # API key for service-to-service calls (notifications)

# =============================================================================
# SalesRabbit Integration
# =============================================================================
SALESRABBIT_WEBHOOK_SECRET=               # HMAC secret for verifying SalesRabbit webhooks

# =============================================================================
# Environment
# =============================================================================
NODE_ENV=development
